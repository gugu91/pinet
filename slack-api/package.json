{
  "name": "@gugu910/pi-slack-api",
  "version": "0.2.0",
  "type": "module",
  "description": "Slack Web API CLI wrapper powered by @slack/web-api",
  "author": "Will Porcellini <5994936+gugu91@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gugu91/pinet.git",
    "directory": "slack-api"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "LICENSE",
    "bin/",
    "dist/"
  ],
  "keywords": [
    "pi-package"
  ],
  "pi": {},
  "bin": {
    "slack-api": "./bin/slack-api"
  },
  "scripts": {
    "build": "node ../scripts/build-package.mjs",
    "prepack": "pnpm run build",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../vitest.config.ts"
  },
  "dependencies": {
    "@slack/web-api": "^7.9.1"
  }
}
