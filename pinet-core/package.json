  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gugu91/extensions.git",
    "directory": "pinet-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "exports": {
