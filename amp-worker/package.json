{
  "name": "@pinet/amp-worker",
  "version": "0.2.4",
  "type": "module",
  "description": "Amp harness worker for the Pinet mesh — executes Amp threads from durable broker inbox assignments",
  "author": "Will Porcellini <5994936+gugu91@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gugu91/pinet.git",
    "directory": "amp-worker"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./amp-runner": "./dist/amp-runner.js",
    "./amp-stream": "./dist/amp-stream.js",
    "./capabilities": "./dist/capabilities.js",
    "./config": "./dist/config.js",
    "./orb-identity": "./dist/orb-identity.js",
    "./state-store": "./dist/state-store.js",
    "./worker": "./dist/worker.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "pinet-amp-worker": "./bin/pinet-amp-worker"
  },
  "files": [
    "README.md",
    "LICENSE",
    "bin/",
    "dist/"
  ],
  "pi": {},
  "scripts": {
    "build": "node ../scripts/build-package.mjs",
    "prepack": "pnpm run build",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../vitest.config.ts"
  },
  "dependencies": {
    "@pinet/broker-core": "file:../broker-core",
    "@pinet/pinet-core": "file:../pinet-core",
    "@pinet/transport-core": "file:../transport-core"
  },
  "types": "./dist/index.d.ts"
}
