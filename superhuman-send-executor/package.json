{
  "name": "@pinet/superhuman-send-executor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Credential-isolated executor for shm-approval-receipt/v1",
  "bin": {
    "pinet-superhuman-send-executor": "dist/src/daemon.js"
  },
