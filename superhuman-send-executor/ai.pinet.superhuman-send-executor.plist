<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
<key>Label</key><string>ai.pinet.superhuman-send-executor</string>
<key>ProgramArguments</key><array>
<string>/usr/local/libexec/pinet-superhuman-send-executor/current/node</string>
<string>/usr/local/libexec/pinet-superhuman-send-executor/current/dist/src/daemon.js</string>
</array>
<key>RunAtLoad</key><true/><key>KeepAlive</key><true/>
<key>ProcessType</key><string>Interactive</string>
<key>StandardOutPath</key><string>/var/log/pinet-superhuman-send-executor.log</string>
<key>StandardErrorPath</key><string>/var/log/pinet-superhuman-send-executor.log</string>
<key>EnvironmentVariables</key><dict><key>PATH</key><string>/usr/bin:/bin</string></dict>
<key>Umask</key><integer>63</integer>
<key>ThrottleInterval</key><integer>10</integer>
</dict></plist>
