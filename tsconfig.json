{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@gugu910/pi-broker-core": ["./broker-core/index.ts"],
      "@gugu910/pi-broker-core/*": ["./broker-core/*.ts"],
      "@gugu910/pi-imessage-bridge": ["./imessage-bridge/index.ts"],
      "@gugu910/pi-pinet-core": ["./pinet-core/index.ts"],
      "@gugu910/pi-pinet-core/*": ["./pinet-core/*.ts"],
      "@gugu910/pi-pinet-web-control-plane": ["./pinet-web-control-plane/index.ts"],
      "@gugu910/pi-transport-core": ["./transport-core/index.ts"]
    }
  },
  "include": [
    "transport-core/**/*.ts",
    "broker-core/**/*.ts",
    "browser-playwright/**/*.ts",
    "imessage-bridge/**/*.ts",
    "pinet-core/**/*.ts",
    "pinet-web-control-plane/**/*.ts",
    "nvim-bridge/**/*.ts",
    "neon-psql/**/*.ts",
    "slack-api/**/*.ts",
    "slack-bridge/**/*.ts",
    "types/**/*.d.ts",
    "vitest.config.ts"
  ]
}
